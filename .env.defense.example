# =============================================================================
# MTS TELECOM - Defense / production-like compose profile
# Copier ce fichier vers .env pour un deploiement defense-ready et adapter
# toutes les valeurs sensibles avant lancement.
# =============================================================================

# === Base de donnees MySQL ===
COMPOSE_DB_PORT=3306
COMPOSE_DB_NAME=mts_telecom_db
COMPOSE_DB_USERNAME=mts_user
COMPOSE_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
COMPOSE_DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

# === JWT / securite ===
COMPOSE_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_64_CHARS
COMPOSE_COOKIE_SECURE=true
ALLOW_INTERNAL_SIGNUP=false
AUTH_EXPOSE_TOKENS_IN_BODY=false

# === URLs publiques coherentes ===
# FRONTEND_BASE_URL = origine publique du frontend (sans /api)
# CORS / WS = origines frontend autorisees uniquement
# REACT_APP_API_URL = URL publique du backend + suffixe /api
COMPOSE_FRONTEND_BASE_URL=https://support.example.com
COMPOSE_CORS_ALLOWED_ORIGINS=https://support.example.com
COMPOSE_WS_ALLOWED_ORIGIN_PATTERNS=https://support.example.com
COMPOSE_REACT_APP_API_URL=https://api.example.com/api
COMPOSE_REACT_APP_GOOGLE_OAUTH_ALLOWED_ORIGINS=https://support.example.com

# === Email verification / SMTP ===
# En profil defense-ready, ces flags doivent rester actives pour imposer
# la verification email des comptes CLIENT.
COMPOSE_AUTH_REQUIRE_EMAIL_VERIFICATION=true
COMPOSE_MAIL_ENABLED=true
COMPOSE_MAIL_HOST=smtp.example.com
COMPOSE_MAIL_PORT=587
COMPOSE_MAIL_USERNAME=no-reply@example.com
COMPOSE_MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
COMPOSE_MAIL_FROM=no-reply@example.com
COMPOSE_MAIL_FROM_NAME=MTS Telecom
COMPOSE_MAIL_SMTP_AUTH=true
COMPOSE_MAIL_SMTP_STARTTLS_ENABLE=true
COMPOSE_MAIL_SMTP_STARTTLS_REQUIRED=false
COMPOSE_MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
COMPOSE_MAIL_SMTP_TIMEOUT_MS=10000
COMPOSE_MAIL_SMTP_WRITE_TIMEOUT_MS=10000
COMPOSE_MANAGEMENT_HEALTH_MAIL_ENABLED=false

# === Google OAuth (optionnel) ===
# Activer seulement si les 2 Client ID sont renseignes et identiques.
COMPOSE_GOOGLE_CLIENT_ID=
COMPOSE_REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
COMPOSE_REACT_APP_GOOGLE_OAUTH_ENABLED=false

# === IA / backend storage ===
AI_AUTOSTART_ENABLED=false
COMPOSE_TICKETS_UPLOAD_DIR=/app/uploads/tickets
COMPOSE_USERS_AVATAR_UPLOAD_DIR=/app/uploads/avatars
COMPOSE_REPORTS_UPLOAD_DIR=/app/uploads/reports

# === Frontend demo mode ===
COMPOSE_REACT_APP_DEMO_MODE=false
