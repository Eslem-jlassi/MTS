# =============================================================================
# MTS TELECOM - Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# Pour un profil defense-ready, partir plutot de .env.defense.example
# =============================================================================

# Profil local de reference
# - timezone de reference appliquee par defaut: Europe/Paris
# - les comptes seedes et mots de passe demo sont documentes dans README.md et les seeds backend
# - ne jamais reutiliser ces exemples tels quels en production

# === Base de donnees MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mts_telecom_db
DB_USERNAME=CHANGE_ME_DB_USERNAME
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

# === Docker Compose (stack conteneurisee officielle) ===
COMPOSE_DB_PORT=3306
COMPOSE_DB_NAME=mts_telecom_db
COMPOSE_DB_USERNAME=CHANGE_ME_COMPOSE_DB_USERNAME
COMPOSE_DB_PASSWORD=CHANGE_ME_COMPOSE_DB_PASSWORD
COMPOSE_DB_ROOT_PASSWORD=CHANGE_ME_COMPOSE_DB_ROOT_PASSWORD

# === JWT ===
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_64_CHARS
COMPOSE_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_64_CHARS

# === Securite ===
# true = permet l'inscription AGENT/MANAGER/ADMIN (dev uniquement)
# false = seul CLIENT peut s'inscrire librement (production)
ALLOW_INTERNAL_SIGNUP=false

# Cookies HttpOnly
# false uniquement pour du dev local en HTTP
COOKIE_SECURE=false
COMPOSE_COOKIE_SECURE=false

# Exposition des tokens dans le body JSON (laisser false pour le navigateur)
AUTH_EXPOSE_TOKENS_IN_BODY=false

# Origines autorisees
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
COMPOSE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COMPOSE_WS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
COMPOSE_FRONTEND_BASE_URL=http://localhost:3000
COMPOSE_AUTH_REQUIRE_EMAIL_VERIFICATION=false

# === Services IA ===
# Laisser false par defaut pour garder un demarrage deterministe en local et en Docker.
AI_AUTOSTART_ENABLED=false
AI_SENTIMENT_BASE_URL=http://127.0.0.1:8000
AI_DUPLICATE_BASE_URL=http://127.0.0.1:8001
AI_CHATBOT_BASE_URL=http://127.0.0.1:8002

# === Google OAuth (optionnel) ===
# Backend Spring Boot - verification du token ID Google
GOOGLE_CLIENT_ID=
COMPOSE_GOOGLE_CLIENT_ID=

# Frontend React - a copier aussi dans client/.env pour "npm start"
# IMPORTANT:
# - activer uniquement si GOOGLE_CLIENT_ID et REACT_APP_GOOGLE_OAUTH_CLIENT_ID sont tous les deux renseignes
# - utiliser exactement le meme Client ID cote backend et frontend
REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
REACT_APP_GOOGLE_OAUTH_ENABLED=false
REACT_APP_GOOGLE_OAUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

COMPOSE_REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
COMPOSE_REACT_APP_GOOGLE_OAUTH_ENABLED=false
COMPOSE_REACT_APP_GOOGLE_OAUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Upload directories in backend container (mounted under /app/uploads)
COMPOSE_TICKETS_UPLOAD_DIR=/app/uploads/tickets
COMPOSE_USERS_AVATAR_UPLOAD_DIR=/app/uploads/avatars
COMPOSE_REPORTS_UPLOAD_DIR=/app/uploads/reports

# === Email / SMTP ===
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@mts-telecom.local
MAIL_FROM_NAME=MTS Telecom
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
MAIL_SMTP_TIMEOUT_MS=10000
MAIL_SMTP_WRITE_TIMEOUT_MS=10000

# Docker Compose SMTP passthrough (optional)
COMPOSE_MAIL_ENABLED=false
COMPOSE_MAIL_HOST=smtp.gmail.com
COMPOSE_MAIL_PORT=587
COMPOSE_MAIL_USERNAME=
COMPOSE_MAIL_PASSWORD=
COMPOSE_MAIL_FROM=no-reply@mts-telecom.local
COMPOSE_MAIL_FROM_NAME=MTS Telecom
COMPOSE_MAIL_SMTP_AUTH=true
COMPOSE_MAIL_SMTP_STARTTLS_ENABLE=true
COMPOSE_MAIL_SMTP_STARTTLS_REQUIRED=false
COMPOSE_MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
COMPOSE_MAIL_SMTP_TIMEOUT_MS=10000
COMPOSE_MAIL_SMTP_WRITE_TIMEOUT_MS=10000

# Verification email / reset password
# Si AUTH_REQUIRE_EMAIL_VERIFICATION=true :
# - MAIL_ENABLED doit aussi etre true
# - FRONTEND_BASE_URL doit pointer vers l'URL publique du frontend
# - le frontend consomme ensuite le lien /verify-email?token=...&email=...
FRONTEND_BASE_URL=http://localhost:3000
AUTH_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_EXPIRATION_HOURS=24
PASSWORD_RESET_EXPIRATION_HOURS=1
AUTH_SENSITIVE_ACTION_CODE_EXPIRATION_MINUTES=10

# Profil SMTP local (Mailpit/MailHog) - exemple rapide
# MAIL_ENABLED=true
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS_ENABLE=false
# AUTH_REQUIRE_EMAIL_VERIFICATION=true
# FRONTEND_BASE_URL=http://localhost:3000
# Interface web Mailpit: http://localhost:8025

# Rate limiting auth endpoints (anti-bruteforce)
AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTER_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_FORGOT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_FORGOT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_RESET_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_RESET_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_RESEND_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_RESEND_WINDOW_SECONDS=300

# === Frontend / mode demonstration ===
# true uniquement si vous activez volontairement les fixtures frontend
REACT_APP_DEMO_MODE=false
REACT_APP_API_URL=http://localhost:8080/api
COMPOSE_REACT_APP_API_URL=http://localhost:8080/api
