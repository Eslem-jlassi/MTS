REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
# true seulement si le backend a aussi GOOGLE_CLIENT_ID configure avec la meme valeur
REACT_APP_GOOGLE_OAUTH_ENABLED=false
REACT_APP_GOOGLE_OAUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

REACT_APP_FRONTEND_ORIGIN=http://localhost:3000
REACT_APP_API_URL=http://localhost:8080/api

# Mode demonstration explicite
# true uniquement si vous voulez charger les fixtures de client/src/demo/*
REACT_APP_DEMO_MODE=false

# Afficher les comptes de test sur la page de connexion
REACT_APP_SHOW_TEST_ACCOUNTS=true
