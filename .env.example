# =============================================================================
# MTS TELECOM - Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# =============================================================================

# === Base de donnees MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mts_telecom_db
DB_USERNAME=mts_user
DB_PASSWORD=mts_password
DB_ROOT_PASSWORD=mts2026

# === Docker Compose (stack conteneurisee officielle) ===
COMPOSE_DB_PORT=3306
COMPOSE_DB_NAME=mts_telecom_db
COMPOSE_DB_USERNAME=mts_user
COMPOSE_DB_PASSWORD=mts_password
COMPOSE_DB_ROOT_PASSWORD=mts2026

# === JWT ===
JWT_SECRET=MTS_BILLCOM_2026_Hx7pL9mNqR3sT6vW8yZ2aB5cD0eF4gHjKlMnPqRsTuVwXyZ1a2B3c4D5e6F7g8H9i0JkLmNoPqRs
COMPOSE_JWT_SECRET=MTS_BILLCOM_2026_Hx7pL9mNqR3sT6vW8yZ2aB5cD0eF4gHjKlMnPqRsTuVwXyZ1a2B3c4D5e6F7g8H9i0JkLmNoPqRs

# === Securite ===
# true = permet l'inscription AGENT/MANAGER/ADMIN (dev uniquement)
# false = seul CLIENT peut s'inscrire librement (production)
ALLOW_INTERNAL_SIGNUP=false

# Cookies HttpOnly
# false uniquement pour du dev local en HTTP
COOKIE_SECURE=false

# Exposition des tokens dans le body JSON (laisser false pour le navigateur)
AUTH_EXPOSE_TOKENS_IN_BODY=false

# Origines autorisees
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
COMPOSE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COMPOSE_WS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000

# === Services IA ===
AI_AUTOSTART_ENABLED=false
AI_SENTIMENT_BASE_URL=http://127.0.0.1:8000
AI_DUPLICATE_BASE_URL=http://127.0.0.1:8001
AI_CHATBOT_BASE_URL=http://127.0.0.1:8002

# === Google OAuth (optionnel) ===
GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
COMPOSE_GOOGLE_CLIENT_ID=
COMPOSE_REACT_APP_GOOGLE_OAUTH_CLIENT_ID=

# === Email / SMTP ===
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@mts-telecom.local
MAIL_FROM_NAME=MTS Telecom
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
MAIL_SMTP_TIMEOUT_MS=10000
MAIL_SMTP_WRITE_TIMEOUT_MS=10000

# Verification email / reset password
FRONTEND_BASE_URL=http://localhost:3000
AUTH_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_EXPIRATION_HOURS=24
PASSWORD_RESET_EXPIRATION_HOURS=1

# === Frontend / mode demonstration ===
# true uniquement si vous activez volontairement les fixtures frontend
REACT_APP_DEMO_MODE=false
REACT_APP_API_URL=http://localhost:8080/api
COMPOSE_REACT_APP_API_URL=http://localhost:8080/api
