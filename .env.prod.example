# =============================================================================
# MTS TELECOM - Docker environment example for stable local demo
# Copy this file to `.env.prod`, then replace every CHANGE_ME value.
# For a real public production deployment, re-enable secure values such as
# COOKIE_SECURE=true and AUTH_REQUIRE_EMAIL_VERIFICATION=true.
# =============================================================================

# === Published ports ===
# For local validation, you can keep frontend on 80 and publish backend on 8085.
COMPOSE_FRONTEND_PORT=80
COMPOSE_BACKEND_PORT=8085

# === Database ===
COMPOSE_DB_NAME=mts_telecom_db
COMPOSE_DB_USERNAME=CHANGE_ME_PROD_DB_USERNAME
COMPOSE_DB_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD
COMPOSE_DB_ROOT_PASSWORD=CHANGE_ME_PROD_DB_ROOT_PASSWORD

# === Security ===
COMPOSE_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_64_CHARS
COMPOSE_COOKIE_SECURE=false
COMPOSE_SERVER_FORWARD_HEADERS_STRATEGY=framework

# === Public URLs ===
# Local demo defaults are used here.
# For real production, keep frontend and backend under the same registrable
# domain when possible (for example support.example.com + api.example.com)
# to stay compatible with cookie auth.
COMPOSE_FRONTEND_BASE_URL=http://localhost
COMPOSE_CORS_ALLOWED_ORIGINS=http://localhost
COMPOSE_WS_ALLOWED_ORIGIN_PATTERNS=http://localhost
COMPOSE_REACT_APP_API_URL=http://localhost:8085/api

# Local Docker validation example:
# COMPOSE_FRONTEND_PORT=80
# COMPOSE_BACKEND_PORT=8085
# COMPOSE_FRONTEND_BASE_URL=http://localhost
# COMPOSE_CORS_ALLOWED_ORIGINS=http://localhost
# COMPOSE_WS_ALLOWED_ORIGIN_PATTERNS=http://localhost
# COMPOSE_REACT_APP_API_URL=http://localhost:8085/api
# COMPOSE_COOKIE_SECURE=false
# COMPOSE_AUTH_REQUIRE_EMAIL_VERIFICATION=false
# COMPOSE_MAIL_ENABLED=false

# === Authentication / signup ===
# Active la verification email en production des qu'un SMTP reel est configure.
COMPOSE_AUTH_REQUIRE_EMAIL_VERIFICATION=false
COMPOSE_REACT_APP_DEMO_MODE=false
COMPOSE_REACT_APP_GOOGLE_OAUTH_ENABLED=false

# === Optional Google OAuth ===
# Pour la demo locale precompilee, `npm run build:demo` masquera Google OAuth
# tant qu'aucun Client ID frontend n'est fourni. Si vous renseignez
# COMPOSE_REACT_APP_GOOGLE_OAUTH_CLIENT_ID avant le build, `http://localhost`
# est deja autorise cote frontend.
COMPOSE_GOOGLE_CLIENT_ID=
COMPOSE_REACT_APP_GOOGLE_OAUTH_CLIENT_ID=
COMPOSE_REACT_APP_GOOGLE_OAUTH_ALLOWED_ORIGINS=http://localhost

# === Optional SMTP ===
# Recommande en production si l'inscription publique CLIENT reste active.
COMPOSE_MAIL_ENABLED=false
COMPOSE_MAIL_HOST=smtp.example.com
COMPOSE_MAIL_PORT=587
COMPOSE_MAIL_USERNAME=no-reply@example.com
COMPOSE_MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
COMPOSE_MAIL_FROM=no-reply@example.com
COMPOSE_MAIL_FROM_NAME=MTS Telecom
COMPOSE_MAIL_SMTP_AUTH=true
COMPOSE_MAIL_SMTP_STARTTLS_ENABLE=true
COMPOSE_MAIL_SMTP_STARTTLS_REQUIRED=false
COMPOSE_MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
COMPOSE_MAIL_SMTP_TIMEOUT_MS=10000
COMPOSE_MAIL_SMTP_WRITE_TIMEOUT_MS=10000
COMPOSE_MANAGEMENT_HEALTH_MAIL_ENABLED=false

# === AI services ===
COMPOSE_AI_SENTIMENT_BASE_URL=http://sentiment-service:8000
COMPOSE_AI_DUPLICATE_BASE_URL=http://duplicate-service:8001
COMPOSE_AI_CHATBOT_BASE_URL=http://ai-chatbot:8002

# === Uploads / runtime ===
COMPOSE_TICKETS_UPLOAD_DIR=/app/uploads/tickets
COMPOSE_USERS_AVATAR_UPLOAD_DIR=/app/uploads/avatars
COMPOSE_REPORTS_UPLOAD_DIR=/app/uploads/reports
COMPOSE_BACKEND_JAVA_OPTS=-Xms256m -Xmx768m

# === Optional branding ===
COMPOSE_REACT_APP_CHATBOT_MASCOT_URL=
